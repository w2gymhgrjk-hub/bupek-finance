# Application
NODE_ENV=development
PORT=4000
APP_NAME=BUPEK Finance API

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/bupek_finance?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# SMS Gateway (Africa's Talking)
SMS_PROVIDER=africastalking
AT_USERNAME=your-at-username
AT_API_KEY=your-at-api-key
AT_SENDER_ID=BUPEK

# Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@bupekfinance.co.tz
SMTP_PASS=your-email-password
EMAIL_FROM=BUPEK Finance <noreply@bupekfinance.co.tz>

# Approval threshold (loans above this require OM approval)
LOAN_APPROVAL_THRESHOLD=5000000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5